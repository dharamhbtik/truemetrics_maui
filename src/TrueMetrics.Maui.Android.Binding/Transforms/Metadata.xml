<metadata>

  <!--
    Fix namespace: map Java package to idiomatic C# namespace.
  -->
  <attr path="/api/package[@name='io.truemetrics.truemetricssdk']"
        name="managedName">TrueMetrics.Sdk.Android</attr>

  <attr path="/api/package[@name='io.truemetrics.truemetricssdk.config']"
        name="managedName">TrueMetrics.Sdk.Android.Config</attr>

  <attr path="/api/package[@name='io.truemetrics.truemetricssdk.engine.state']"
        name="managedName">TrueMetrics.Sdk.Android.State</attr>

  <attr path="/api/package[@name='io.truemetrics.truemetricssdk.engine.stats']"
        name="managedName">TrueMetrics.Sdk.Android.Stats</attr>

  <attr path="/api/package[@name='io.truemetrics.truemetricssdk.engine.sensor.model']"
        name="managedName">TrueMetrics.Sdk.Android.Sensor</attr>

  <!--
    Remove internal/obfuscated packages that should not be exposed.
    The single-letter packages (a, b, c, d) are R8-obfuscated internals.
  -->
  <remove-node path="/api/package[@name='a']" />
  <remove-node path="/api/package[@name='b']" />
  <remove-node path="/api/package[@name='c']" />
  <remove-node path="/api/package[@name='d']" />

  <!--
    Remove internal access$ synthetic methods generated by Kotlin compiler.
    These are not part of the public API.
  -->
  <remove-node path="/api/package[@name='io.truemetrics.truemetricssdk']/class[@name='TruemetricsSdk']/method[starts-with(@name,'access$')]" />

  <!--
    Remove the internal DefaultConstructorMarker constructor (Kotlin internal).
  -->
  <remove-node path="/api/package[@name='io.truemetrics.truemetricssdk']/class[@name='TruemetricsSdk']/constructor[contains(@params,'kotlin.jvm.internal.DefaultConstructorMarker')]" />
  <remove-node path="/api/package[@name='io.truemetrics.truemetricssdk.config']/class[@name='SdkConfiguration']/constructor[contains(@params,'kotlin.jvm.internal.DefaultConstructorMarker')]" />

  <!--
    Rename TruemetricsSdk to TrueMetricsSdk for .NET naming conventions.
  -->
  <attr path="/api/package[@name='io.truemetrics.truemetricssdk']/class[@name='TruemetricsSdk']"
        name="managedName">TrueMetricsSdk</attr>

  <!--
    Rename Companion objects to follow .NET conventions.
  -->
  <attr path="/api/package[@name='io.truemetrics.truemetricssdk']/class[@name='TruemetricsSdk.Companion']"
        name="managedName">TrueMetricsSdkCompanion</attr>

  <attr path="/api/package[@name='io.truemetrics.truemetricssdk.config']/class[@name='SdkConfiguration.Companion']"
        name="managedName">SdkConfigurationCompanion</attr>

  <!--
    Remove Kotlin internal copy$default methods from Builder.
  -->
  <remove-node path="/api/package[@name='io.truemetrics.truemetricssdk.config']/class[@name='SdkConfiguration.Builder']/method[starts-with(@name,'copy')]" />

  <!--
    Remove internal engine packages not needed in public API surface.
  -->
  <remove-node path="/api/package[@name='io.truemetrics.truemetricssdk.engine.configuration.data.local']" />
  <remove-node path="/api/package[@name='io.truemetrics.truemetricssdk.engine.configuration.data.network']" />
