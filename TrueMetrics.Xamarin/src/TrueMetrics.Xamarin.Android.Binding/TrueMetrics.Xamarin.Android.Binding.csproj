<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" DefaultTargets="Build"
         xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProductVersion>8.0.30703</ProductVersion>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{B2C3D4E5-F6A7-8901-BCDE-F12345678902}</ProjectGuid>
    <ProjectTypeGuids>{EFBA0AD7-5A72-4C68-AF49-83D382785DCF};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <OutputType>Library</OutputType>
    <RootNamespace>TrueMetrics.Xamarin.Android.Binding</RootNamespace>
    <AssemblyName>TrueMetrics.Xamarin.Android.Binding</AssemblyName>
    <TargetFrameworkVersion>v13.0</TargetFrameworkVersion>
    <TargetFrameworkIdentifier>MonoAndroid</TargetFrameworkIdentifier>
    <!-- Skip NuGet asset resolution — binding has no package deps -->
    <ResolveNuGetPackages>false</ResolveNuGetPackages>
    <!-- class-parse is required for Kotlin-compiled JARs; jar2xml cannot parse them -->
    <AndroidClassParser>class-parse</AndroidClassParser>
    <Nullable>enable</Nullable>
    <LangVersion>9.0</LangVersion>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug</OutputPath>
    <DefineConstants>DEBUG;</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugSymbols>false</DebugSymbols>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release</OutputPath>
    <DefineConstants>RELEASE;</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <!-- Mono.Android, Java.Interop, and System are required by class-parse generated code -->
  <ItemGroup>
    <Reference Include="Mono.Android" />
    <Reference Include="Java.Interop" />
    <Reference Include="System" />
  </ItemGroup>

  <ItemGroup>
    <!--
      The AAR provides native resources, AndroidManifest, and the bundled
      sentry-shaded.jar (libs/). Bind=false so the generator does NOT
      try to bind the Sentry internals from the AAR's libs/ folder.
    -->
    <AndroidLibrary Include="Jars\truemetricssdk-1.4.6.aar">
      <Bind>false</Bind>
    </AndroidLibrary>

    <!--
      classes.jar (extracted from the AAR) contains the public TrueMetrics SDK API.
      We bind only this jar so the generator produces clean C# bindings for
      io.truemetrics.truemetricssdk.* only.
    -->
    <EmbeddedJar Include="Jars\truemetricssdk-classes.jar" />
  </ItemGroup>

  <ItemGroup>
    <TransformFile Include="Transforms\Metadata.xml" />
    <TransformFile Include="Transforms\EnumFields.xml" />
    <TransformFile Include="Transforms\EnumMethods.xml" />
  </ItemGroup>

  <Import Project="$(MSBuildExtensionsPath)\Xamarin\Android\Xamarin.Android.Bindings.targets" />

</Project>
